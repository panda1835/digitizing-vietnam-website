# Strapi API Base URL (e.g. http://localhost:1337)
NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337

# Backend URL (if different from Strapi URL)
NEXT_PUBLIC_BACKEND_URL=http://localhost:1337

# Next.js API/Site URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Algolia Search Credentials (optional, if using Search features)
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_API_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=
